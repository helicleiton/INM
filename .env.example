# Copie para .env.local e preencha com os dados do projeto Firebase (Configurações do projeto → Seus apps).
# Na Vercel: Project → Settings → Environment Variables (mesmos nomes, prefixo VITE_).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
