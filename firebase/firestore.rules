rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Conteúdo público do site (um documento com o mesmo shape de content.json)
    match /site/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Formulários públicos (contato, voluntário, doação)
    match /inboxMessages/{id} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'message', 'source'])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.message is string
        && request.resource.data.source in ['contact', 'volunteer', 'donation'];

      allow read, update, delete: if request.auth != null;
    }
  }
}
